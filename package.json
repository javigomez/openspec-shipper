{
  "name": "openspec-shipper",
  "version": "0.2.0",
  "description": "Ship OpenSpec changes through an agent-backed queue.",
  "license": "MIT",
  "bin": {
    "openspec-shipper": "dist/infrastructure/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "private": false,
  "scripts": {
    "queue:next": "bun run index.ts queue next",
    "queue:run": "bun run index.ts queue run",
    "queue:status": "bun run index.ts queue status",
    "queue:dry-run": "bun run index.ts queue dry-run",
    "queue:stop": "bun run index.ts queue stop",
    "queue:stats": "bun run index.ts queue stats",
    "target:setup": "bun run index.ts setup-target",
    "target:init": "bun run index.ts init",
    "target:update": "bun run index.ts update",
    "target:doctor": "bun run index.ts doctor",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "release-patch": "node scripts/release-patch.mjs",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
